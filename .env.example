
# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# 必填。Prisma 运行时使用的 PostgreSQL 连接地址。
# Neon 推荐填写 pooler 地址，用于应用运行时连接。
# 示例：
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL=""

# 可选。Prisma 迁移/同步结构时使用的直连地址。
# 当前 schema.prisma 尚未启用 directUrl，所以此项暂时不会被 Prisma 读取。
# 如果后续在 prisma/schema.prisma 中添加 directUrl = env("DIRECT_URL")，则需要配置它。
# 示例：
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL=""

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# 必填。用于签名后台登录 Session Cookie。
# 生产环境缺少 AUTH_SECRET / NEXTAUTH_SECRET 时，项目会拒绝启动。
# 生成方式：
# openssl rand -hex 32
AUTH_SECRET=""

# 可选。兼容旧命名；只有未设置 AUTH_SECRET 时才会读取。
# NEXTAUTH_SECRET=""
